---
import '../styles/global.css';
---

<html lang="sl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Mladi Pirati — Podmladek Piratske stranke Slovenije</title>
    <meta name="description" content="Mladi Pirati smo podmladek Piratske stranke Slovenije. Zavzemamo se za digitalne pravice, transparentnost, svobodo in prihodnost mladih." />
    <link rel="icon" type="image/png" href="/logos/Pirati_MladiPirati_Logo_1.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Monda:wght@400;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
  </head>
  <body>

    <!-- HERO -->
    <section class="hero" id="hero">
      <canvas class="hero-ascii" id="hero-ascii" aria-hidden="true"></canvas>
      <div class="hero-inner">
        <h1 class="form-preamble">Svet je v razsulu.</h1>
        <p class="hero-quote-text">Vsi, ki <span id="hero-quote-loop"></span></p>
        <form class="hero-form" id="signup-form" aria-label="Pristopnica za Mlade Pirate" autocomplete="off" novalidate>
          <div class="prompt-line"><label for="ime" class="prompt-label">ime</label><input type="text" id="ime" name="ime" placeholder="kako ti je ime?" minlength="2" required /></div>
          <div class="prompt-line"><label for="priimek" class="prompt-label">priimek</label><input type="text" id="priimek" name="priimek" placeholder="in priimek?" minlength="2" required /></div>
          <div class="prompt-line"><label for="email" class="prompt-label">email</label><input type="email" id="email" name="email" placeholder="obljubimo, brez spama" required /></div>
          <div class="prompt-line"><label for="starost" class="prompt-label">letnik rojstva</label><input type="text" id="starost" name="starost" placeholder="npr. 2002" inputmode="numeric" pattern="(199[4-9]|200\d|201[0-0])" required /></div>
          <div class="prompt-line"><label for="mesto" class="prompt-label">mesto</label><input type="text" id="mesto" name="mesto" placeholder="npr. Ljubljana" required /></div>
          <div class="prompt-line prompt-line-wide"><label for="motivacija" class="prompt-label">motivacija <span class="prompt-hint">(maks. 100 besed)</span></label><textarea id="motivacija" name="motivacija" rows="2" maxlength="600" placeholder="kaj bi spremenil/a?"></textarea></div>
          <button type="submit" class="form-submit">pridruži se nam</button>
          <div class="form-consent" id="form-consent">
            <p class="consent-title">S to izjavo dajem soglasje do preklica:</p>
            <label class="consent-check"><input type="checkbox" id="consent-data" required /><span>da Mladi Pirati skladno z veljavno zakonodajo s področja varstva osebnih podatkov in Splošno uredbo EU o varstvu podatkov zbirajo, obdelujejo, uporabljajo, shranjujejo in ažurirajo moje osebne podatke ter mi po elektronski pošti pošiljajo obvestila v zvezi s članstvom in aktivnostmi organizacije.</span></label>
            <button type="button" class="form-submit" id="consent-submit">potrdi in pošlji</button>
            <button type="button" class="form-back" id="consent-back">← nazaj</button>
          </div>
        </form>
        <p class="hero-quote-cta">Podmladek Piratske stranke Slovenije</p>
      </div>

      <!-- NAV (bottom of hero) -->
      <nav class="site-nav" id="site-nav">
        <div class="nav-inner">
          <a href="/" class="nav-brand">
            <img src="/logos/Pirati_MladiPirati_Logo_3.png" alt="Mladi Pirati" />
          </a>
          <ul class="nav-menu" id="nav-menu">
            <li><a href="#o-nas">O nas</a></li>
            <li><a href="#program">Program</a></li>
            <li><a href="/novice">Novice</a></li>
            <li><a href="/dogodki">Dogodki</a></li>
            <li><a href="#hero" class="nav-highlight">Pridruži se</a></li>
          </ul>
          <button class="scroll-down-arrow" id="scroll-arrow" aria-label="Pomakni se navzdol"><span class="arrow-pair"><svg width="14" height="10" viewBox="0 0 14 10" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><rect x="0" y="0" width="2" height="2"/><rect x="12" y="0" width="2" height="2"/><rect x="2" y="2" width="2" height="2"/><rect x="10" y="2" width="2" height="2"/><rect x="4" y="4" width="2" height="2"/><rect x="8" y="4" width="2" height="2"/><rect x="6" y="6" width="2" height="2"/></svg><svg width="14" height="10" viewBox="0 0 14 10" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><rect x="0" y="0" width="2" height="2"/><rect x="12" y="0" width="2" height="2"/><rect x="2" y="2" width="2" height="2"/><rect x="10" y="2" width="2" height="2"/><rect x="4" y="4" width="2" height="2"/><rect x="8" y="4" width="2" height="2"/><rect x="6" y="6" width="2" height="2"/></svg></span></button>
          <button class="nav-toggle" id="nav-toggle" aria-label="Odpri meni">&#9776;</button>
        </div>
      </nav>
    </section>

    <main>
    <!-- O NAS -->
    <hr class="section-divider" role="presentation" />
    <section class="section" id="o-nas">
      <div class="container">
        <div class="content-block">
          <h2 class="section-title">O <span class="accent">nas</span></h2>
          <p class="section-subtitle">Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
          <div class="about-text">
            <p>
              Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.
            </p>
            <p>
              Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum.
            </p>
            <p>
              Ut enim ad minima veniam, quis nostrum exercitationem ullam corporis suscipit laboriosam, nisi ut aliquid ex ea commodi consequatur.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- PROGRAM -->
    <hr class="section-divider" role="presentation" />
    <section class="section section--alt" id="program">
      <div class="container">
        <div class="content-block">
          <h2 class="section-title">Naš <span class="accent">program</span></h2>
          <p class="section-subtitle">Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
          <div class="pillars-list">
            <div class="pillar-row">
              <div class="pillar-content">
                <h3>Lorem Ipsum</h3>
                <p>Sed ut perspiciatis unde omnis iste natus error sit voluptatem accusantium doloremque laudantium.</p>
              </div>
            </div>
            <div class="pillar-row">
              <div class="pillar-content">
                <h3>Dolor Sit Amet</h3>
                <p>Nemo enim ipsam voluptatem quia voluptas sit aspernatur aut odit aut fugit.</p>
              </div>
            </div>
            <div class="pillar-row">
              <div class="pillar-content">
                <h3>Consectetur</h3>
                <p>Neque porro quisquam est, qui dolorem ipsum quia dolor sit amet, consectetur, adipisci velit.</p>
              </div>
            </div>
            <div class="pillar-row">
              <div class="pillar-content">
                <h3>Adipiscing Elit</h3>
                <p>Quis autem vel eum iure reprehenderit qui in ea voluptate velit esse quam nihil molestiae.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    </main>

    <!-- FOOTER -->
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-top">
          <div class="footer-text-row">
            <span class="footer-brand-text">Podmladek Piratske stranke Slovenije.</span>
            <ul class="footer-links">
              <li><a href="/zasebnost">Politika zasebnosti in varovanje osebnih podatkov</a></li>
              <li><a href="/dostopnost">Izjava o dostopnosti</a></li>
            </ul>
          </div>
        </div>
        <hr class="footer-divider" />
        <div class="footer-bottom">
          <p>&copy; 2018–2026 Mladi Pirati. Vse pravice pridržane.</p>
          <div class="footer-socials">
            <a href="#" aria-label="Instagram"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.17.054 1.97.24 2.43.403a4.088 4.088 0 011.523.99 4.088 4.088 0 01.99 1.524c.163.46.349 1.26.403 2.43.058 1.265.07 1.645.07 4.849s-.012 3.584-.07 4.85c-.054 1.17-.24 1.97-.403 2.43a4.088 4.088 0 01-.99 1.523 4.088 4.088 0 01-1.524.99c-.46.163-1.26.349-2.43.403-1.265.058-1.645.07-4.849.07s-3.584-.012-4.85-.07c-1.17-.054-1.97-.24-2.43-.403a4.088 4.088 0 01-1.523-.99 4.088 4.088 0 01-.99-1.524c-.163-.46-.349-1.26-.403-2.43C2.175 15.584 2.163 15.204 2.163 12s.012-3.584.07-4.85c.054-1.17.24-1.97.403-2.43a4.088 4.088 0 01.99-1.523A4.088 4.088 0 015.15 2.636c.46-.163 1.26-.349 2.43-.403C8.845 2.175 9.225 2.163 12 2.163M12 0C8.741 0 8.333.014 7.053.072 5.775.131 4.902.333 4.14.63a6.21 6.21 0 00-2.245 1.462A6.21 6.21 0 00.433 4.337C.136 5.1-.066 5.973-.007 7.251-.068 8.53-.082 8.938-.082 12.197s.014 3.668.072 4.948c.059 1.277.261 2.15.558 2.913a6.21 6.21 0 001.462 2.245 6.21 6.21 0 002.245 1.462c.763.297 1.636.499 2.913.558C8.333 23.986 8.741 24 12 24s3.668-.014 4.948-.072c1.277-.059 2.15-.261 2.913-.558a6.21 6.21 0 002.245-1.462 6.21 6.21 0 001.462-2.245c.297-.763.499-1.636.558-2.913.058-1.28.072-1.688.072-4.948s-.014-3.668-.072-4.948c-.059-1.277-.261-2.15-.558-2.913a6.21 6.21 0 00-1.462-2.245A6.21 6.21 0 0019.861.63C19.1.333 18.225.131 16.948.072 15.668.014 15.26 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg></a>
            <a href="#" aria-label="Discord"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.333-.947 2.418-2.157 2.418z"/></svg></a>
          </div>
        </div>
      </div>
    </footer>

    <script>
      // ===== VARIABLE TYPOGRAPHIC ASCII WAVES =====
      (function () {
        const canvas = document.getElementById('hero-ascii');
        if (!canvas) return;
        const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const ctx = canvas.getContext('2d');

        const FONT_SIZE = 14;
        const CELL_W = FONT_SIZE * 0.6;
        const CELL_H = FONT_SIZE;
        const CHARSET = ' .,:;!+-=*#@%&abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
        const WEIGHTS = [300, 500, 800];
        const FONT_FAMILY = "'JetBrains Mono', monospace";

        let cols = 0, rows = 0, time = 0;

        // --- build brightness palette ---
        const bCanvas = document.createElement('canvas');
        bCanvas.width = 28; bCanvas.height = 28;
        const bCtx = bCanvas.getContext('2d', { willReadFrequently: true });

        function estimateBrightness(ch, font) {
          bCtx.clearRect(0, 0, 28, 28);
          bCtx.font = font;
          bCtx.fillStyle = '#fff';
          bCtx.textBaseline = 'middle';
          bCtx.fillText(ch, 1, 14);
          const data = bCtx.getImageData(0, 0, 28, 28).data;
          let sum = 0;
          for (let i = 3; i < data.length; i += 4) sum += data[i];
          return sum / (255 * 28 * 28);
        }

        const palette = [];
        for (const weight of WEIGHTS) {
          const font = weight + ' ' + FONT_SIZE + 'px ' + FONT_FAMILY;
          for (const ch of CHARSET) {
            if (ch === ' ') continue;
            const brightness = estimateBrightness(ch, font);
            if (brightness <= 0) continue;
            palette.push({ char: ch, weight, font, brightness });
          }
        }
        const maxB = Math.max(...palette.map(e => e.brightness));
        if (maxB > 0) palette.forEach(e => e.brightness /= maxB);
        palette.sort((a, b) => a.brightness - b.brightness);

        function findChar(targetB) {
          let lo = 0, hi = palette.length - 1;
          while (lo < hi) {
            const mid = (lo + hi) >> 1;
            if (palette[mid].brightness < targetB) lo = mid + 1;
            else hi = mid;
          }
          let best = palette[lo], bestScore = Infinity;
          const start = Math.max(0, lo - 10), end = Math.min(palette.length, lo + 10);
          for (let i = start; i < end; i++) {
            const score = Math.abs(palette[i].brightness - targetB);
            if (score < bestScore) { bestScore = score; best = palette[i]; }
          }
          return best;
        }

        function resize() {
          const dpr = window.devicePixelRatio || 1;
          const w = canvas.parentElement.offsetWidth;
          const h = canvas.parentElement.offsetHeight;
          canvas.width = w * dpr;
          canvas.height = h * dpr;
          canvas.style.width = w + 'px';
          canvas.style.height = h + 'px';
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
          cols = Math.floor(w / CELL_W);
          rows = Math.floor(h / CELL_H);
        }

        function draw() {
          time += 0.012;
          const w = canvas.width / (window.devicePixelRatio || 1);
          const h = canvas.height / (window.devicePixelRatio || 1);
          ctx.clearRect(0, 0, w, h);
          ctx.textBaseline = 'top';

          const cx = cols / 2;
          const cy = rows / 2;

          for (let y = 0; y < rows; y++) {
            for (let x = 0; x < cols; x++) {
              const wave1 = Math.sin(x * 0.08 + y * 0.06 + time);
              const wave2 = Math.sin(x * 0.12 - y * 0.09 + time * 1.3);
              const wave3 = Math.cos((x + y) * 0.05 + time * 0.7);
              const val = (wave1 + wave2 + wave3) / 3;

              const intensity = (val + 1) / 2;

              const dx = (x - cx) / cx;
              const dy = (y - cy) / cy;
              const dist = Math.sqrt(dx * dx + dy * dy);
              const vignette = Math.min(dist * 0.9, 1);

              const brightness = intensity * vignette;
              if (brightness < 0.02) continue;

              const entry = findChar(brightness);
              const alpha = brightness * 0.4;
              ctx.font = entry.font;
              ctx.fillStyle = 'rgba(240, 160, 0, ' + alpha.toFixed(3) + ')';
              ctx.fillText(entry.char, x * CELL_W, y * CELL_H);
            }
          }

          if (!reducedMotion) requestAnimationFrame(draw);
        }

        resize();
        draw();
        window.addEventListener('resize', resize);
      })();

      // ===== QUOTE LOOP ANIMATION =====
      (function () {
        const el = document.getElementById('hero-quote-loop');
        if (!el) return;

        const scrambleChars = '.:=-~+*/%#@|\\<>[]{}';
        const phrases = [
          { text: 'nimate svojega stanovanja.', accent: null },
          { text: 'ste naveličani korupcije.', accent: null },
          { text: 'hočete, da se to spremeni', accent: 'spremeni' }
        ];

        const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const fps = 24;
        const frameInterval = 1000 / fps;
        const holdTime = 1200;

        function randomChar() {
          return scrambleChars[Math.floor(Math.random() * scrambleChars.length)];
        }

        function accentify(str, accentWord) {
          if (!accentWord) return str;
          const i = str.indexOf(accentWord);
          if (i === -1) return str;
          return str.slice(0, i) + '<span class="accent">' + accentWord + '</span>' + str.slice(i + accentWord.length);
        }

        if (reducedMotion) {
          const last = phrases[phrases.length - 1];
          el.innerHTML = accentify(last.text, last.accent) + '<span class="blink-cursor">&gt;</span>';
          return;
        }

        function decodeIn(text, accentWord) {
          return new Promise((resolve) => {
            const letters = text.split('');
            const charIndices = [];
            letters.forEach((c, i) => {
              if (c !== ' ') charIndices.push(i);
            });
            const total = charIndices.length;

            const settleAt = charIndices.map((_, i) => {
              const turnStart = (i / total) * 30;
              return Math.floor(turnStart + 6 + Math.random() * 10);
            });
            const activateAt = settleAt.map(s => Math.max(0, s - 12));
            const totalFrames = Math.max(...settleAt) + 4;

            const current = letters.map(c => c === ' ' ? ' ' : ' ');
            let frame = 0;

            const interval = setInterval(() => {
              frame++;
              for (let j = 0; j < charIndices.length; j++) {
                const idx = charIndices[j];
                if (frame < activateAt[j]) {
                  current[idx] = ' ';
                } else if (frame >= settleAt[j]) {
                  current[idx] = letters[idx];
                } else {
                  current[idx] = randomChar();
                }
              }
              el.textContent = current.join('');

              if (frame >= totalFrames) {
                clearInterval(interval);
                el.innerHTML = accentify(text, accentWord);
                resolve();
              }
            }, frameInterval);
          });
        }

        function scrambleOut(text) {
          return new Promise((resolve) => {
            const letters = text.split('');
            const charIndices = [];
            letters.forEach((c, i) => {
              if (c !== ' ') charIndices.push(i);
            });
            const total = charIndices.length;

            // dissolve left-to-right
            const dissolveAt = charIndices.map((_, i) => {
              return Math.floor((i / total) * 20 + Math.random() * 8);
            });
            const totalFrames = Math.max(...dissolveAt) + 6;

            const current = letters.slice();
            let frame = 0;

            const interval = setInterval(() => {
              frame++;
              for (let j = 0; j < charIndices.length; j++) {
                const idx = charIndices[j];
                if (frame >= dissolveAt[j] + 5) {
                  current[idx] = ' ';
                } else if (frame >= dissolveAt[j]) {
                  current[idx] = randomChar();
                }
              }
              el.textContent = current.join('');

              if (frame >= totalFrames) {
                clearInterval(interval);
                el.textContent = '';
                resolve();
              }
            }, frameInterval);
          });
        }

        function sleep(ms) {
          return new Promise(r => setTimeout(r, ms));
        }

        async function run() {
          for (let i = 0; i < phrases.length; i++) {
            await decodeIn(phrases[i].text, phrases[i].accent);
            if (i < phrases.length - 1) {
              await sleep(holdTime);
              await scrambleOut(phrases[i].text);
              await sleep(200);
            }
          }
          el.innerHTML = el.innerHTML + '<span class="blink-cursor">&gt;</span>';
        }

        sleep(600).then(run);
      })();

      // ===== FORM SUBMISSION (two-step: fields → consent) =====
      const signupForm = document.getElementById('signup-form');
      const consentPanel = document.getElementById('form-consent');
      const consentSubmit = document.getElementById('consent-submit');
      const consentBack = document.getElementById('consent-back');

      function shakeInvalid(form) {
        const fields = form.querySelectorAll('input, textarea');
        let firstBad = null;
        fields.forEach(f => {
          const row = f.closest('.prompt-line');
          if (!row) return;
          row.classList.remove('is-invalid', 'shake');
          if (!f.checkValidity()) {
            if (!firstBad) firstBad = f;
            row.classList.add('is-invalid', 'shake');
            row.addEventListener('animationend', () => row.classList.remove('shake'), { once: true });
          }
        });
        if (firstBad) firstBad.focus();
        return !firstBad;
      }

      // clear error on input
      signupForm?.addEventListener('input', (e) => {
        const row = e.target.closest('.prompt-line');
        if (row && e.target.checkValidity()) row.classList.remove('is-invalid');
      });

      // Step 1: validate fields, then show consent
      signupForm?.addEventListener('submit', (e) => {
        e.preventDefault();
        if (!shakeInvalid(signupForm)) return;
        signupForm.classList.add('show-consent');
      });

      // Back button: return to fields
      consentBack?.addEventListener('click', () => {
        signupForm.classList.remove('show-consent');
      });

      // Step 2: validate consent checkboxes, then submit
      consentSubmit?.addEventListener('click', () => {
        const c1 = document.getElementById('consent-data');
        if (!c1.checked) {
          c1.closest('.consent-check')?.classList.add('shake');
          c1.closest('.consent-check')?.addEventListener('animationend', function() { this.classList.remove('shake'); }, { once: true });
          return;
        }
        consentPanel.innerHTML = '<p class="consent-done">hvala! kmalu se slišimo.</p>';
      });

      // ===== STICKY NAV =====
      const hero = document.getElementById('hero');
      const nav = document.getElementById('site-nav');

      const observer = new IntersectionObserver(
        ([entry]) => {
          if (!entry.isIntersecting) {
            nav.classList.add('is-fixed');
          } else {
            nav.classList.remove('is-fixed');
          }
        },
        { threshold: 0, rootMargin: '-70px 0px 0px 0px' }
      );

      if (hero && nav) {
        observer.observe(hero);
      }

      // Scroll-down arrow
      const arrow = document.getElementById('scroll-arrow');
      arrow?.addEventListener('click', () => {
        document.getElementById('o-nas')?.scrollIntoView({ behavior: 'smooth' });
      });

      // Mobile nav toggle
      const toggle = document.getElementById('nav-toggle');
      const menu = document.getElementById('nav-menu');
      toggle?.addEventListener('click', () => {
        menu?.classList.toggle('is-open');
      });

      menu?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          menu.classList.remove('is-open');
        });
      });

      // Smooth scroll for anchor links
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', (e) => {
          const href = anchor.getAttribute('href');
          if (!href || href === '#') return;
          const target = document.querySelector(href);
          if (target) {
            e.preventDefault();
            const offset = 70;
            const y = target.getBoundingClientRect().top + window.scrollY - offset;
            window.scrollTo({ top: y, behavior: 'smooth' });
          }
        });
      });
    </script>
  </body>
</html>
