---
import '../styles/global.css';
---

<html lang="sl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Form Previews — Mladi Pirati</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Monda:wght@400;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <style>
      body {
        padding: 60px 0;
      }
      .preview-section {
        max-width: 500px;
        margin: 0 auto 80px;
        padding: 0 24px;
      }
      .preview-label {
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px;
        color: #f0a000;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 8px;
        padding-bottom: 8px;
        border-bottom: 1px solid #222;
      }
      .preview-desc {
        font-size: 13px;
        color: rgba(255,255,255,0.4);
        margin-bottom: 24px;
        line-height: 1.6;
      }
      .preview-divider {
        border: none;
        border-top: 1px solid #222;
        margin: 80px auto;
        max-width: 500px;
      }

      /* ===== VARIANT 1: MONOSPACE TERMINAL ===== */
      .form-v1 {
        font-family: 'JetBrains Mono', monospace;
      }
      .form-v1 .fg {
        margin-bottom: 16px;
      }
      .form-v1 label {
        display: block;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: #f0a000;
        margin-bottom: 6px;
      }
      .form-v1 label::before {
        content: '> ';
        color: rgba(240, 160, 0, 0.4);
      }
      .form-v1 input,
      .form-v1 textarea {
        width: 100%;
        padding: 10px 12px;
        background: #0a0a0a;
        border: 1px solid #333;
        border-radius: 0;
        color: #fff;
        font-family: 'JetBrains Mono', monospace;
        font-size: 14px;
        caret-color: #f0a000;
      }
      .form-v1 input::placeholder,
      .form-v1 textarea::placeholder {
        color: rgba(255,255,255,0.15);
      }
      .form-v1 input:focus,
      .form-v1 textarea:focus {
        outline: none;
        border-color: #f0a000;
        box-shadow: 0 0 0 1px rgba(240, 160, 0, 0.2);
      }
      .form-v1 .fr {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }
      .form-v1 button {
        width: 100%;
        margin-top: 4px;
        padding: 12px;
        background: #f0a000;
        color: #000;
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        border: none;
        border-radius: 0;
        cursor: pointer;
      }
      .form-v1 button:hover {
        background: #ffb833;
      }

      /* ===== VARIANT 2: ASCII FRAME ===== */
      .form-v2-frame {
        font-family: 'JetBrains Mono', monospace;
        position: relative;
        padding: 28px 24px;
      }
      .form-v2-border {
        position: absolute;
        inset: 0;
        pointer-events: none;
        color: rgba(240, 160, 0, 0.25);
        font-size: 14px;
        line-height: 1;
        overflow: hidden;
      }
      .form-v2-border-top,
      .form-v2-border-bottom {
        position: absolute;
        left: 0;
        right: 0;
        display: flex;
      }
      .form-v2-border-top {
        top: 0;
      }
      .form-v2-border-bottom {
        bottom: 0;
      }
      .form-v2-border-left,
      .form-v2-border-right {
        position: absolute;
        top: 14px;
        bottom: 14px;
        width: 14px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: center;
      }
      .form-v2-border-left { left: 0; }
      .form-v2-border-right { right: 0; }
      .form-v2-border-left span,
      .form-v2-border-right span {
        display: block;
      }
      .form-v2-title {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: rgba(240, 160, 0, 0.5);
        text-align: center;
        margin-bottom: 20px;
      }
      .form-v2 .fg {
        margin-bottom: 14px;
      }
      .form-v2 label {
        display: block;
        font-size: 11px;
        font-weight: 400;
        color: rgba(255,255,255,0.4);
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 4px;
      }
      .form-v2 input,
      .form-v2 textarea {
        width: 100%;
        padding: 8px 10px;
        background: rgba(240, 160, 0, 0.03);
        border: 1px solid rgba(240, 160, 0, 0.15);
        border-radius: 0;
        color: #fff;
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px;
        caret-color: #f0a000;
      }
      .form-v2 input::placeholder,
      .form-v2 textarea::placeholder {
        color: rgba(255,255,255,0.12);
      }
      .form-v2 input:focus,
      .form-v2 textarea:focus {
        outline: none;
        border-color: rgba(240, 160, 0, 0.5);
      }
      .form-v2 .fr {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
      }
      .form-v2 button {
        width: 100%;
        margin-top: 6px;
        padding: 10px;
        background: transparent;
        color: #f0a000;
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        border: 1px solid rgba(240, 160, 0, 0.4);
        border-radius: 0;
        cursor: pointer;
      }
      .form-v2 button:hover {
        background: rgba(240, 160, 0, 0.08);
        border-color: #f0a000;
      }

      /* ===== VARIANT 3: GLITCH LABELS ===== */
      .form-v3 {
        font-family: 'Inter', sans-serif;
      }
      .form-v3 .fg {
        margin-bottom: 18px;
      }
      .form-v3 label {
        display: block;
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: #f0a000;
        margin-bottom: 6px;
        min-height: 18px;
      }
      .form-v3 input,
      .form-v3 textarea {
        width: 100%;
        padding: 11px 14px;
        background: #1a1a1a;
        border: 1px solid #333;
        border-radius: 4px;
        color: #fff;
        font-family: 'Inter', sans-serif;
        font-size: 14px;
        caret-color: #f0a000;
      }
      .form-v3 input::placeholder,
      .form-v3 textarea::placeholder {
        color: rgba(255,255,255,0.2);
      }
      .form-v3 input:focus,
      .form-v3 textarea:focus {
        outline: none;
        border-color: #f0a000;
      }
      .form-v3 .fr {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
      }
      .form-v3 button {
        width: 100%;
        margin-top: 4px;
        padding: 13px;
        background: #f0a000;
        color: #000;
        font-size: 14px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
      }
      .form-v3 button:hover {
        background: #ffb833;
      }

      /* ===== VARIANT 4: TERMINAL PROMPT ===== */
      .form-v4 {
        font-family: 'JetBrains Mono', monospace;
      }
      .form-v4 .prompt-line {
        display: flex;
        align-items: center;
        gap: 0;
        margin-bottom: 8px;
        border-bottom: 1px solid #1a1a1a;
        padding-bottom: 8px;
      }
      .form-v4 .prompt-label {
        font-size: 13px;
        color: #f0a000;
        white-space: nowrap;
        flex-shrink: 0;
        padding-right: 4px;
      }
      .form-v4 input,
      .form-v4 textarea {
        flex: 1;
        width: 100%;
        padding: 6px 0;
        background: transparent;
        border: none;
        color: #fff;
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px;
        caret-color: #f0a000;
      }
      .form-v4 input::placeholder,
      .form-v4 textarea::placeholder {
        color: rgba(255,255,255,0.15);
      }
      .form-v4 input:focus,
      .form-v4 textarea:focus {
        outline: none;
      }
      .form-v4 textarea {
        resize: none;
      }
      .form-v4 .prompt-line-wide {
        flex-direction: column;
        align-items: flex-start;
        gap: 4px;
      }
      .form-v4 .prompt-line-wide .prompt-label {
        margin-bottom: 2px;
      }
      .form-v4 button {
        width: 100%;
        margin-top: 12px;
        padding: 10px;
        background: transparent;
        color: #f0a000;
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px;
        font-weight: 400;
        border: none;
        border-radius: 0;
        cursor: pointer;
        text-align: left;
        border-top: 1px solid #222;
        padding-top: 16px;
      }
      .form-v4 button::before {
        content: '$ ';
        color: rgba(240, 160, 0, 0.4);
      }
      .form-v4 button:hover {
        color: #ffb833;
      }
    </style>
  </head>
  <body>

    <!-- V1: MONOSPACE TERMINAL -->
    <div class="preview-section">
      <div class="preview-label">Variant 1: Monospace Terminal</div>
      <p class="preview-desc">JetBrains Mono throughout, sharp edges, > prefixed labels, solid orange submit.</p>
      <form class="form-v1" onsubmit="return false">
        <div class="fr">
          <div class="fg"><label for="v1-ime">Ime</label><input type="text" id="v1-ime" placeholder="Tvoje ime" /></div>
          <div class="fg"><label for="v1-priimek">Priimek</label><input type="text" id="v1-priimek" placeholder="Tvoj priimek" /></div>
        </div>
        <div class="fg"><label for="v1-email">E-naslov</label><input type="email" id="v1-email" placeholder="tvoj@email.si" /></div>
        <div class="fr">
          <div class="fg"><label for="v1-starost">Letnik rojstva</label><input type="number" id="v1-starost" placeholder="npr. 2002" /></div>
          <div class="fg"><label for="v1-mesto">Mesto / občina</label><input type="text" id="v1-mesto" placeholder="npr. Ljubljana" /></div>
        </div>
        <div class="fg"><label for="v1-mot">Zakaj se želiš pridružiti?</label><textarea id="v1-mot" rows="3" placeholder="Povej nam kaj o sebi..."></textarea></div>
        <button type="submit">Pošlji pristopnico</button>
      </form>
    </div>

    <hr class="preview-divider" />

    <!-- V2: ASCII FRAME -->
    <div class="preview-section">
      <div class="preview-label">Variant 2: ASCII Frame</div>
      <p class="preview-desc">Box drawn with ASCII border characters in dim orange. TUI window aesthetic. Ghost outline submit.</p>
      <div class="form-v2-frame">
        <div class="form-v2-border">
          <div class="form-v2-border-top">┌────────────────────────────────────────────────────────────┐</div>
          <div class="form-v2-border-bottom">└────────────────────────────────────────────────────────────┘</div>
          <div class="form-v2-border-left"><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span></div>
          <div class="form-v2-border-right"><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span><span>│</span></div>
        </div>
        <div class="form-v2-title">[ pristopnica ]</div>
        <form class="form-v2" onsubmit="return false">
          <div class="fr">
            <div class="fg"><label for="v2-ime">Ime</label><input type="text" id="v2-ime" placeholder="Tvoje ime" /></div>
            <div class="fg"><label for="v2-priimek">Priimek</label><input type="text" id="v2-priimek" placeholder="Tvoj priimek" /></div>
          </div>
          <div class="fg"><label for="v2-email">E-naslov</label><input type="email" id="v2-email" placeholder="tvoj@email.si" /></div>
          <div class="fr">
            <div class="fg"><label for="v2-starost">Letnik</label><input type="number" id="v2-starost" placeholder="npr. 2002" /></div>
            <div class="fg"><label for="v2-mesto">Mesto</label><input type="text" id="v2-mesto" placeholder="npr. Ljubljana" /></div>
          </div>
          <div class="fg"><label for="v2-mot">Motivacija</label><textarea id="v2-mot" rows="2" placeholder="Povej nam kaj o sebi..."></textarea></div>
          <button type="submit">[ pošlji ]</button>
        </form>
      </div>
    </div>

    <hr class="preview-divider" />

    <!-- V3: GLITCH LABELS -->
    <div class="preview-section">
      <div class="preview-label">Variant 3: Glitch Labels</div>
      <p class="preview-desc">Standard layout but labels scramble-decode on load, same effect as the hero quote. Orange monospace labels, rounded inputs.</p>
      <form class="form-v3" onsubmit="return false">
        <div class="fr">
          <div class="fg"><label data-text="Ime" class="glitch-label"></label><input type="text" placeholder="Tvoje ime" /></div>
          <div class="fg"><label data-text="Priimek" class="glitch-label"></label><input type="text" placeholder="Tvoj priimek" /></div>
        </div>
        <div class="fg"><label data-text="E-naslov" class="glitch-label"></label><input type="email" placeholder="tvoj@email.si" /></div>
        <div class="fr">
          <div class="fg"><label data-text="Letnik rojstva" class="glitch-label"></label><input type="number" placeholder="npr. 2002" /></div>
          <div class="fg"><label data-text="Mesto / občina" class="glitch-label"></label><input type="text" placeholder="npr. Ljubljana" /></div>
        </div>
        <div class="fg"><label data-text="Zakaj se želiš pridružiti?" class="glitch-label"></label><textarea rows="3" placeholder="Povej nam kaj o sebi..."></textarea></div>
        <button type="submit">Pošlji pristopnico</button>
      </form>
    </div>

    <hr class="preview-divider" />

    <!-- V4: TERMINAL PROMPT -->
    <div class="preview-section">
      <div class="preview-label">Variant 4: Terminal Prompt</div>
      <p class="preview-desc">Each field is a command line. Label as inline prefix, input runs to the right. No boxes, no borders, just lines.</p>
      <form class="form-v4" onsubmit="return false">
        <div class="prompt-line"><span class="prompt-label">ime &gt;</span><input type="text" placeholder="Tvoje ime" /></div>
        <div class="prompt-line"><span class="prompt-label">priimek &gt;</span><input type="text" placeholder="Tvoj priimek" /></div>
        <div class="prompt-line"><span class="prompt-label">email &gt;</span><input type="email" placeholder="tvoj@email.si" /></div>
        <div class="prompt-line"><span class="prompt-label">letnik &gt;</span><input type="number" placeholder="npr. 2002" /></div>
        <div class="prompt-line"><span class="prompt-label">mesto &gt;</span><input type="text" placeholder="npr. Ljubljana" /></div>
        <div class="prompt-line prompt-line-wide"><span class="prompt-label">motivacija &gt;</span><textarea rows="2" placeholder="Povej nam kaj o sebi..."></textarea></div>
        <button type="submit">pošlji pristopnico</button>
      </form>
    </div>

    <script>
      // Glitch labels for V3
      (function () {
        const scrambleChars = '.:=-~+*/%#@|\\<>[]{}!?&^';
        const labels = document.querySelectorAll('.glitch-label');

        function randomChar() {
          return scrambleChars[Math.floor(Math.random() * scrambleChars.length)];
        }

        labels.forEach((label, li) => {
          const text = label.getAttribute('data-text');
          if (!text) return;
          const letters = text.split('');
          const delay = li * 120;

          // start scrambled
          label.textContent = letters.map(c => c === ' ' ? ' ' : randomChar()).join('');

          setTimeout(() => {
            const settleFrames = letters.map((_, i) => {
              return Math.floor((i / letters.length) * 20 + Math.random() * 8);
            });
            const totalFrames = Math.max(...settleFrames) + 1;
            let frame = 0;
            const current = letters.map(c => c === ' ' ? ' ' : randomChar());

            const interval = setInterval(() => {
              frame++;
              for (let j = 0; j < letters.length; j++) {
                if (letters[j] === ' ') continue;
                if (frame >= settleFrames[j]) {
                  current[j] = letters[j];
                } else {
                  current[j] = randomChar();
                }
              }
              label.textContent = current.join('');
              if (frame >= totalFrames) {
                clearInterval(interval);
                label.textContent = text;
              }
            }, 33);
          }, 500 + delay);
        });
      })();
    </script>
  </body>
</html>
